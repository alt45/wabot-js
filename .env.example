# ─── WhatsApp Bot Config ───────────────────────────────
# Prefix command bot (default: !)
BOT_PREFIX=!

# Nomor WhatsApp Owner (tanpa +, gunakan kode negara)
# Contoh: 628123456789
OWNER_NUMBER=628xxxxxxxxxx

# ID grup target untuk status forwarder
# Cara dapat: kirim pesan di grup, lihat log JID di console
TARGET_GROUP_ID=120363xxxxxx@g.us

# Timezone (untuk penjadwalan reminder)
TZ=Asia/Jakarta

# ─── Dashboard & API Security ──────────────────────────
# Port untuk web dashboard
WEB_PORT=3000

# Password untuk masuk ke Admin Dashboard
ADMIN_PASSWORD=admin123

# Bearer Token untuk akses API dari luar (Python/Curl/dll)
API_TOKEN=my-secret-token-123

# ─── Integrasi API Eksternal ───────────────────────────
# Daftar gratis di: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key

# Kota default untuk perintah !cuaca
DEFAULT_CITY=Semarang
